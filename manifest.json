{
    "manifest_version": 3,
    "name": "Timbers Matchday",
    "version": "1.0.0",
    "description": "Track Portland Timbers matches and engage with other fans",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "storage",
        "alarms"
    ],
    "host_permissions": [
        "https://www.mlssoccer.com/*"
    ],
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}
